<launch>
    <arg name="diff_drive_params" default="diff_params.yaml" description="Which yaml file (in pkg nuturltebot_description) should be used for the diff drive robot parameters?"/>
    <arg name="cmd_src" default="none" description="launch circle node, turtlebot3_teleop teleop_twist_keyboard, or no control node">
        <choice value="circle"/>
        <choice value="teleop"/>
        <choice value="none"/>
    </arg>
    <arg name="robot" default="none" description="nusim will launch a simulated robot, 'localhost' should be used to run this launchfile on the turtlebot. 'none' will not launch any robot nodes.">
        <choice value="nusim"/>
        <choice value="localhost"/>
        <choice value="none"/>
    </arg>
    <arg name="use_rviz" default="true" description="(bool): Do you want to launch rviz?"/>

    <!-- If robot == localhost -->
    <group if="$(equals $(var robot) localhost)">

        <node pkg="nuturtle_control" exec="turtle_control">
            <param from="$(find-pkg-share nuturtle_description)/config/$(var diff_drive_params)"/>
        </node>

        <node pkg="nuturtle_control" exec="odometry">
            <param from="$(find-pkg-share nuturtle_description)/config/$(var diff_drive_params)"/>
            <param name="wheel_left" value="'left'"/>
            <param name="wheel_right" value="'right'"/>
            <param name="body_id" value="'blue/base_footprint'"/>
        </node>

        <include file="$(find-pkg-share hls_lfcd_lds_driver)/launch/hlds_laser.launch.py">
            <arg name="port" value="/dev/ttyUSB0"/>
            <arg name="frame_id" value="laser"/> <!-- 'laser' is default-->
        </include>

        <!-- Placeholder spot for numsr_turtlebot node -->
    </group>


    <!-- If robot != localhost -->
    <group unless="$(equals $(var robot) localhost)">

        <node pkg="tf2_ros" exec="static_transform_publisher" args="0 0 0 0 0 0 nusim/world odom" />

        <!-- If robot == nusim -->
        <group if="$(equals $(var robot) nusim)">

            <include file="$(find-pkg-share nusim)/launch/nusim.launch.xml">
                <arg name="use_rviz" value="false"/>
                <arg name="use_jsp" value="false"/>
            </include>

            <node pkg="nuturtle_control" exec="odometry">
                <param from="$(find-pkg-share nuturtle_description)/config/$(var diff_drive_params)"/>
                <param name="wheel_left" value="blue/wheel_left_joint"/>
                <param name="wheel_right" value="blue/wheel_right_joint"/>
                <param name="body_id" value="'blue/base_footprint'"/>
                <remap from="joint_states" to="red/joint_states"/>
                <remap from="path" to="blue/path"/>

            </node>

            <node pkg="nuturtle_control" exec="turtle_control">
                <param from="$(find-pkg-share nuturtle_description)/config/$(var diff_drive_params)"/>
                <remap from="wheel_cmd" to="red/wheel_cmd"/>
                <remap from="sensor_data" to="red/sensor_data"/>
                <remap from="joint_states" to="red/joint_states"/>
            </node>

            <node pkg="rviz2" exec="rviz2" on_exit="shutdown" args="-d $(find-pkg-share nuturtle_control)/config/sim_odom.rviz"/>
        </group>


        <group if="$(equals $(var robot) none)">
            <node pkg="rviz2" exec="rviz2" on_exit="shutdown" args="-d $(find-pkg-share nuturtle_control)/config/real_odom.rviz"/>
        </group>

        <!-- If robot == none, then no 'extra' stuff is launched-->

        <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="use_rviz" value="False"/>
            <arg name="color" value="blue"/>
            <arg name="use_jsp" value="false"/>
        </include>

        <!-- Deal with cmd_src -->
        <node pkg="nuturtle_control" exec="circle" if="$(equals $(var cmd_src) circle)">
            <param name="frequency" value="100"/>
        </node>

        <node pkg="teleop_twist_keyboard" exec="teleop_twist_keyboard" if="$(equals $(var cmd_src) teleop)"/>

    </group>

</launch>