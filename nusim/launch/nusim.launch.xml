
<launch>
    <arg name="config_file" default="basic_world.yaml" description="What yaml file to load obstacle and turtlebot initial positions from."/>
    <arg name="use_rviz" default="true" description="(bool): Do you want to launch rviz?"/>
    <arg name="use_jsp" default="true" description="(bool): Do you want to launch the joint_state_publisher?"/>
    <arg name="draw_only" default="false" description="(bool): False runs full simulator, true only publishes landmark markers."/>


    <node pkg="nusim" exec="nusim" unless="$(var draw_only)">
        <param from="$(find-pkg-share nusim)/config/$(var config_file)"/>
        <param name="external_jsp" value="$(var use_jsp)"/>
        <param name="draw_only" value="$(var draw_only)"/>
    </node>

    <node pkg="nusim" exec="nusim" name="nuwalls" if="$(var draw_only)">
        <param from="$(find-pkg-share nusim)/config/$(var config_file)"/>
        <param name="external_jsp" value="$(var use_jsp)"/>
        <param name="draw_only" value="$(var draw_only)"/>
    </node>

    <node pkg="rviz2" exec="rviz2" if="$(var use_rviz)" on_exit="shutdown" args="-d $(find-pkg-share nusim)/config/nusim.rviz" />

    <!-- Need to load in a red turtlebot -->
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
        <arg name="use_jsp" value="$(var use_jsp)"/>
        <arg name="use_rviz" value="False"/>
        <arg name="color" value="red"/>
    </include>

</launch>