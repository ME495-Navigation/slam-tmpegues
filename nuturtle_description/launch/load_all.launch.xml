<launch>
    <arg name="use_rviz" default="True" description="True will open rviz, False will not open rviz"/>

    <!-- ##### Begin_Citation [4] ##### -->
         <!-- Citation is only for the on_exit="shutdown", for I simply could not find how to do that -->
    <node pkg="rviz2" exec="rviz2" on_exit="shutdown" args="-d $(find-pkg-share nuturtle_description)/config/basic_all.rviz" if="$(var use_rviz)"/>
    <!-- #####  End_Citation [4]  ##### -->

    <!-- 1. Publish an initial tf for nusim/world to all of the base_links -->
    <node pkg="tf2_ros" exec="static_transform_publisher" namespace="purple"
        args="0 -1.0 0 1.57 0 0 nusim/world purple/base_footprint" />
    <node pkg="tf2_ros" exec="static_transform_publisher" namespace="red"
        args="0.25 0 0 3.14 0 0 nusim/world red/base_footprint" />
    <node pkg="tf2_ros" exec="static_transform_publisher" namespace="green"
        args="0 0.5 0 -1.57 0 0 nusim/world green/base_footprint" />
    <node pkg="tf2_ros" exec="static_transform_publisher" namespace="blue"
        args="-0.5 0 0 0 0 0 nusim/world blue/base_footprint" />

    <!-- 2. Launch the urdfs -->
    <group>
        <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="use_rviz" value="False"/>
            <arg name="color" value="purple"/>
        </include>
        <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="use_rviz" value="False"/>
            <arg name="color" value="red"/>
        </include>
        <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="use_rviz" value="False"/>
            <arg name="color" value="blue"/>
        </include>
            <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="use_rviz" value="False"/>
            <arg name="color" value="green"/>
        </include>
    </group>

</launch>