    <launch>
    <arg name="use_rviz" default="true" description="true will open rviz, false will not open rviz">
        <choice value="true"/>
        <choice value="false"/>
    </arg>
    <arg name="use_jsp" default="true" description="frue will use joint_state_publisher, false will not use joint_state_publisher">
        <choice value="true"/>
        <choice value="false"/>
    </arg>
    <arg name="color" default="purple" description="What color do you want your turtle to be?">
        <!-- ##### Begin_Citation [3] ##### -->
        <choice value="purple"/>
        <choice value="red"/>
        <choice value="green"/>
        <choice value="blue"/>
        <!-- #####  End_Citation [3]  ##### -->
    </arg>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" namespace="$(var color)">
        <param name="frame_prefix" value="$(var color)/"/>
        <param name="robot_description" value="$(command '$(exec-in-pkg xacro xacro) $(find-pkg-share nuturtle_description)/urdf/turtlebot3_burger.urdf.xacro color:=$(var color)')" />
    </node>

    <node pkg="joint_state_publisher" exec="joint_state_publisher" namespace="$(var color)" if="$(var use_jsp)"/>
    <node pkg="rviz2" exec="rviz2" on_exit="shutdown" args="-d $(find-pkg-share nuturtle_description)/config/load_one_$(var color).rviz" namespace="$(var color)" if="$(var use_rviz)"/>

</launch>